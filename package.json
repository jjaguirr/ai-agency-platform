{
  "name": "ai-agency-platform",
  "version": "2.1.0",
  "type": "module",
  "description": "AI Agency Platform with MCPhub integration and multi-agent orchestration",
  "main": "src/coordinators/langgraph-coordinator.js",
  "scripts": {
    "start": "node src/coordinators/langgraph-coordinator.js",
    "dev": "nodemon src/coordinators/langgraph-coordinator.js",
    "test": "jest",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "setup:infrastructure": "./scripts/init-communication-gateways.sh",
    "setup:mcphub": "docker-compose up -d mcphub postgres redis qdrant",
    "health": "curl -f http://localhost:3000/health && echo 'MCPhub healthy'"
  },
  "dependencies": {
    "@langchain/openai": "^0.3.15",
    "@langchain/mcp-adapters": "^0.1.5",
    "@langchain/langgraph": "^0.2.19",
    "@langchain/core": "^0.3.21",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.1",
    "@qdrant/js-client-rest": "^1.12.0",
    "express": "^4.21.2",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^11.0.3",
    "winston": "^3.17.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "jest": "^29.7.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "@types/node": "^22.10.2",
    "supertest": "^7.0.0"
  },
  "keywords": [
    "ai-agents",
    "mcphub", 
    "langgraph",
    "multi-agent",
    "orchestration",
    "mcp",
    "enterprise-ai"
  ],
  "author": "AI Agency Platform Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-agency/ai-platform.git"
  }
}