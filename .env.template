# AI Agency Platform - Complete Environment Configuration
# Copy this to .env and configure with your actual values

# ====================================================================
# CORE PLATFORM CONFIGURATION
# ====================================================================

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Security - CHANGE THESE IN PRODUCTION
JWT_SECRET=your-super-secret-jwt-secret-at-least-32-chars-change-in-production
ENCRYPTION_KEY=your-32-char-encryption-key-for-data-protection-change-this

# ====================================================================
# AI MODEL API KEYS
# ====================================================================

# OpenAI (Required for Infrastructure agents)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-openai-org-id-here

# Anthropic Claude (Required for Infrastructure agents)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Optional AI Models
DEEPSEEK_API_KEY=your-deepseek-api-key-here
META_API_KEY=your-meta-api-key-here

# ====================================================================
# DATABASE CONFIGURATION
# ====================================================================

# PostgreSQL - Langfuse
LANGFUSE_DB_PASSWORD=langfuse_secure_password_change_me

# PostgreSQL - MCPhub  
MCPHUB_DB_PASSWORD=mcphub_secure_password_change_me

# Redis
REDIS_PASSWORD=redis_secure_password_change_me

# ====================================================================
# LANGFUSE CONFIGURATION
# ====================================================================

# Langfuse Core Settings
LANGFUSE_SECRET=your-super-secret-nextauth-secret-at-least-32-chars-change-in-production
LANGFUSE_SALT=your-super-secret-salt-at-least-32-chars-change-in-production

# Langfuse API Keys (Generated after setup - leave blank initially)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Langfuse Features
LANGFUSE_TELEMETRY=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true

# ====================================================================
# MCPHUB CONFIGURATION
# ====================================================================

# MCPhub API
MCPHUB_API_KEY=mcphub-api-key-generate-after-setup
MCPHUB_BASE_URL=http://localhost:3000

# MCPhub Features
MCPHUB_INTEGRATION_ENABLED=true
LANGFUSE_ENABLED=true
LANGFUSE_BASE_URL=http://localhost:3001

# ====================================================================
# DEVELOPMENT SETTINGS (Comment out for production)
# ====================================================================

DEVELOPMENT_MODE=true
ENABLE_DEBUG_LOGGING=true

# ====================================================================
# PRODUCTION SETTINGS (Uncomment for production)
# ====================================================================

# NODE_ENV=production
# LOG_LEVEL=info
# DEVELOPMENT_MODE=false
# ENABLE_DEBUG_LOGGING=false

# ====================================================================
# SETUP INSTRUCTIONS
# ====================================================================

# 1. Copy this file: cp .env.template .env
# 2. Add your OpenAI and Anthropic API keys (required)
# 3. Change all passwords and secrets (use: openssl rand -hex 32)
# 4. Deploy: docker-compose -f docker-compose.langfuse.yml up -d
# 5. Setup Langfuse: ./scripts/initialize-langfuse.sh
# 6. Add Langfuse API keys to this file after setup
# 7. Restart services: docker-compose -f docker-compose.langfuse.yml restart

# ====================================================================
# SECURITY NOTES
# ====================================================================

# CRITICAL: Never commit .env with real credentials to git
# Generate secure passwords: openssl rand -hex 32
# Rotate API keys regularly
# Use different secrets for development/production