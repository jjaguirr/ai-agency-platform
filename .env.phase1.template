# AI Agency Platform - Phase 1 Configuration Template
# Copy this to .env.phase1 and fill in your own values
# NEVER commit the actual .env.phase1 file to git

# MCPhub Configuration
MCPHUB_PORT=3000
MCPHUB_JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE
DATABASE_URL=postgresql://mcphub:YOUR_DATABASE_PASSWORD@localhost:5433/mcphub

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Cross-System Communication
CLAUDE_CODE_BRIDGE_ENABLED=true
CUSTOMER_ISOLATION_LEVEL=complete
AI_MODEL_SWITCHING_ENABLED=true

# Security Configuration
SECURITY_AUDIT_ENABLED=true
CUSTOMER_DATA_ENCRYPTION=true

# Development Configuration
LOG_LEVEL=debug
DEVELOPMENT_MODE=true

# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.phase1
# 2. Generate a secure JWT secret: openssl rand -hex 32
# 3. Choose a strong database password
# 4. Never commit .env.phase1 to git!