# AI Agency Platform - Langfuse Integration Environment Configuration
# Copy this to .env.langfuse and configure with your actual values

# ====================================================================
# LANGFUSE CONFIGURATION
# ====================================================================

# Database Configuration
LANGFUSE_DB_PASSWORD=langfuse_super_secure_password_change_me
LANGFUSE_SECRET=your-super-secret-nextauth-secret-at-least-32-chars-change-in-production
LANGFUSE_SALT=your-super-secret-salt-at-least-32-chars-change-in-production

# Langfuse API Keys (generated after first login)
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here

# Feature Flags
LANGFUSE_TELEMETRY=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=true

# Worker Configuration
LANGFUSE_WORKER_CONCURRENCY=2
LANGFUSE_WORKER_TIMEOUT=60000

# ====================================================================
# MCPHUB INTEGRATION CONFIGURATION  
# ====================================================================

# MCPhub Database
MCPHUB_DB_PASSWORD=mcphub_super_secure_password_change_me

# MCPhub API Configuration
MCPHUB_API_KEY=mcphub-api-key-generate-after-setup
JWT_SECRET=your-super-secret-jwt-secret-at-least-32-chars

# ====================================================================
# AI MODEL API KEYS
# ====================================================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_ORG_ID=org-your-openai-org-id-here

# Anthropic Claude Configuration  
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# DeepSeek Configuration (optional)
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# Meta Llama Configuration (optional, for local deployment)
META_API_KEY=your-meta-api-key-here

# ====================================================================
# INFRASTRUCTURE CONFIGURATION
# ====================================================================

# Redis Configuration
REDIS_PASSWORD=redis_super_secure_password_change_me

# Additional Security
ENCRYPTION_KEY=your-32-char-encryption-key-for-data-protection

# ====================================================================
# DEVELOPMENT CONFIGURATION
# ====================================================================

# Environment
NODE_ENV=development
LOG_LEVEL=debug

# Development Features
DEVELOPMENT_MODE=true
ENABLE_DEBUG_LOGGING=true

# ====================================================================
# PRODUCTION CONFIGURATION (uncomment for production)
# ====================================================================

# NODE_ENV=production
# LOG_LEVEL=info
# DEVELOPMENT_MODE=false
# ENABLE_DEBUG_LOGGING=false
# LANGFUSE_TELEMETRY=false

# ====================================================================
# SECURITY NOTES
# ====================================================================

# IMPORTANT: 
# 1. Change ALL default passwords and secrets before production use
# 2. Use strong, randomly generated passwords (32+ characters)
# 3. Store API keys securely and rotate them regularly
# 4. Never commit this file with real credentials to version control
# 5. Use environment-specific .env files (.env.development, .env.production)

# Password Generation Examples:
# openssl rand -hex 32
# openssl rand -base64 32

# ====================================================================
# LANGFUSE INITIAL SETUP NOTES
# ====================================================================

# After first deployment:
# 1. Navigate to http://localhost:3001
# 2. Create admin account
# 3. Create "AI Agency Platform" project
# 4. Generate API keys in project settings
# 5. Update LANGFUSE_PUBLIC_KEY and LANGFUSE_SECRET_KEY above
# 6. Restart services to apply new configuration