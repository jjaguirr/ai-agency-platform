# WhatsApp Webhook Service - Production Environment Configuration
# Meta-Compliant Production Configuration for Tech Provider Status

# ==============================================
# FLASK APPLICATION CONFIGURATION
# ==============================================
FLASK_ENV=production
FLASK_APP=src.webhook.whatsapp_webhook_service:app
ENVIRONMENT=production
LOG_LEVEL=INFO
PYTHON_UNBUFFERED=1

# ==============================================
# META BUSINESS API CONFIGURATION (Required)
# ==============================================
# Meta App Configuration (obtain from Meta Developer Console)
META_APP_ID=your-meta-app-id-here
META_APP_SECRET=your-meta-app-secret-here
META_API_VERSION=v20.0

# Embedded Signup Configuration ID (from Meta Developer Console)
EMBEDDED_SIGNUP_CONFIG_ID=your-configuration-id-here

# Meta Business Token TTL (60 days = 5184000 seconds)
META_BUSINESS_TOKEN_TTL=5184000

# Meta webhook verification for embedded signup
META_WEBHOOK_VERIFY_TOKEN=meta-embedded-signup-verify-12345

# ==============================================
# WHATSAPP BUSINESS API CONFIGURATION
# ==============================================
# WhatsApp Business API Tokens
WHATSAPP_VERIFY_TOKEN=ai-agency-platform-verify-token-12345
WHATSAPP_BUSINESS_TOKEN=your-whatsapp-business-api-token-here
WHATSAPP_BUSINESS_PHONE_ID=your-phone-number-id-here

# Webhook signature validation secret
WHATSAPP_WEBHOOK_SECRET=your-webhook-signature-secret-here

# ==============================================
# SECURITY CONFIGURATION
# ==============================================
# Production security settings
PRODUCTION_MODE=true
ENABLE_IP_ALLOWLIST=true
ENFORCE_WEBHOOK_SECRET=true
SECURE_COOKIES=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# AES-256 encryption key for business tokens (32 characters)
ENCRYPTION_KEY=your-32-character-encryption-key!!
META_TOKEN_ENCRYPTION_KEY=your-meta-token-encryption-key-32!!

# JWT configuration for client authentication
JWT_SECRET=your-secure-jwt-secret-min-32-characters-long-production

# ==============================================
# REDIS CONFIGURATION (Client Registry)
# ==============================================
# DigitalOcean Managed Redis URL
REDIS_URL=rediss://username:password@your-redis-cluster.db.ondigitalocean.com:25061/0

# Redis connection configuration
REDIS_MAX_CONNECTIONS=100
REDIS_SOCKET_TIMEOUT=5
REDIS_SOCKET_CONNECT_TIMEOUT=10

# ==============================================
# RATE LIMITING CONFIGURATION
# ==============================================
RATE_LIMIT_STORAGE=redis
RATE_LIMIT_STORAGE_URL=${REDIS_URL}

# Rate limits for different endpoints
RATE_LIMIT_DEFAULT=1000 per hour
RATE_LIMIT_WEBHOOK=10000 per hour
RATE_LIMIT_EMBEDDED_SIGNUP=100 per hour
RATE_LIMIT_CLIENT_REGISTRATION=50 per hour

# ==============================================
# EA INTEGRATION CONFIGURATION
# ==============================================
EA_INTEGRATION_ENABLED=true
EA_DEFAULT_TIMEOUT=30
EA_MAX_RETRIES=3
EA_CIRCUIT_BREAKER_ENABLED=true
EA_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
EA_CIRCUIT_BREAKER_RESET_TIMEOUT=60

# ==============================================
# MONITORING AND OBSERVABILITY
# ==============================================
# Metrics and monitoring
METRICS_ENABLED=true
PROMETHEUS_PORT=9090
DATADOG_API_KEY=your-datadog-api-key-here
DATADOG_SERVICE_NAME=whatsapp-webhook-service
DATADOG_ENV=production

# Health check configuration
HEALTH_CHECK_TIMEOUT=10
HEALTH_CHECK_META_APIS=true
HEALTH_CHECK_REDIS=true
HEALTH_CHECK_EA_ENDPOINTS=true

# ==============================================
# BUSINESS MODEL CONFIGURATION
# ==============================================
# Multi-tenant configuration
CLIENT_ONBOARDING_MODE=embedded_signup
MULTI_TENANT_MODE=true
CUSTOMER_ISOLATION_ENABLED=true

# Client provisioning configuration
CLIENT_PROVISIONING_TIMEOUT=30
CLIENT_AUTO_SETUP_EA=true
CLIENT_DEFAULT_TIER=starter

# ==============================================
# VOICE INTEGRATION (Optional)
# ==============================================
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
VOICE_INTEGRATION_ENABLED=true
VOICE_DEFAULT_MODEL=eleven_monolingual_v1
VOICE_DEFAULT_VOICE=21m00Tcm4TlvDq8ikWAM

# ==============================================
# PERFORMANCE CONFIGURATION
# ==============================================
# Gunicorn worker configuration
GUNICORN_WORKERS=4
GUNICORN_MAX_REQUESTS=10000
GUNICORN_MAX_REQUESTS_JITTER=1000
GUNICORN_TIMEOUT=120
GUNICORN_WORKER_CONNECTIONS=1000

# HTTP configuration
HTTP_TIMEOUT=30
HTTP_MAX_CONNECTIONS=100
HTTP_MAX_KEEPALIVE_CONNECTIONS=20

# ==============================================
# CORS AND DOMAIN CONFIGURATION
# ==============================================
# Allowed origins for CORS (Meta requirements)
CORS_ALLOWED_ORIGINS=https://webhook.aiagency.platform,https://business.facebook.com,https://developers.facebook.com

# Primary webhook domain (HTTPS required by Meta)
PRIMARY_WEBHOOK_DOMAIN=https://webhook.aiagency.platform
EMBEDDED_SIGNUP_DOMAIN=https://whatsapp.aiagency.platform

# ==============================================
# DATABASE CONFIGURATION (Future)
# ==============================================
# PostgreSQL for persistent client data (if needed)
DATABASE_URL=postgresql://user:password@your-postgres-cluster.db.ondigitalocean.com:25060/webhook_service

# ==============================================
# DEPLOYMENT CONFIGURATION
# ==============================================
APP_VERSION=2.0.0
BUILD_VERSION=${BUILD_VERSION:-latest}
DEPLOYMENT_TIMESTAMP=${DEPLOYMENT_TIMESTAMP}

# Container configuration
CONTAINER_PORT=8000
CONTAINER_MEMORY_LIMIT=1Gi
CONTAINER_CPU_LIMIT=1000m

# ==============================================
# FEATURE FLAGS
# ==============================================
# Feature toggles for gradual rollout
FEATURE_ENHANCED_LOGGING=true
FEATURE_ADVANCED_METRICS=true
FEATURE_AUTO_SCALING_HINTS=true
FEATURE_CIRCUIT_BREAKER=true
FEATURE_DISTRIBUTED_TRACING=true

# ==============================================
# BACKUP AND RECOVERY
# ==============================================
# Redis backup configuration
REDIS_BACKUP_ENABLED=true
REDIS_BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM
REDIS_BACKUP_RETENTION_DAYS=7

# Client data backup
CLIENT_DATA_BACKUP_ENABLED=true
CLIENT_DATA_BACKUP_SCHEDULE="0 3 * * *"  # Daily at 3 AM

# ==============================================
# PRODUCTION DEPLOYMENT VALIDATION
# ==============================================
# Pre-deployment health checks
VALIDATE_META_APP_CONFIG=true
VALIDATE_WHATSAPP_BUSINESS_API=true
VALIDATE_REDIS_CONNECTION=true
VALIDATE_DOMAIN_SSL=true
VALIDATE_WEBHOOK_ENDPOINTS=true

# ==============================================
# PRODUCTION NOTES
# ==============================================
#
# 1. Security Requirements:
#    - All secrets must be 32+ characters with high entropy
#    - Use DigitalOcean App Platform secrets management
#    - Enable IP allowlisting for webhook endpoints
#    - Validate all webhook signatures from Meta
#    - Use HTTPS only (HTTP disabled in production)
#
# 2. Meta Tech Provider Requirements:
#    - Webhook endpoints must respond within 20 seconds
#    - Must handle 99.9% uptime SLA for business customers
#    - All customer data encrypted at rest and in transit
#    - Proper error handling and retry mechanisms
#    - Support for multiple WABA per business account
#
# 3. Performance Requirements:
#    - Handle 10,000+ webhook requests per hour
#    - <2 second response time for 95th percentile
#    - <500ms response time for 90th percentile
#    - Support auto-scaling from 2 to 8 instances
#
# 4. Business Model Support:
#    - Support embedded signup for "acquire EA WhatsApp services"
#    - Multi-tenant architecture with customer isolation
#    - Per-customer billing and usage tracking
#    - Automated EA provisioning upon successful onboarding
#
# 5. Monitoring Requirements:
#    - Real-time health monitoring of all components
#    - Performance metrics and alerting
#    - Business metrics (signups, conversions, retention)
#    - Error tracking and logging for debugging
#