# AI Agency Platform - Security API Configuration (Bypass Mode)
# Security API returns 'safe' for all content - for development only
# 
# Copy this file to .env.security and configure your settings

# JWT Configuration (Required for authentication)
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# Security Mode Configuration
LLAMAGUARD_ENABLED=false  # Bypass mode for development

# API Configuration
LOG_LEVEL=INFO
SECURITY_API_PORT=8083