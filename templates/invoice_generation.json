{
  "name": "Invoice Generation",
  "description": "Generate and send invoices based on completed work or recurring schedules",
  "category": "finance",
  "triggers": [{"type": "event", "event": "project_milestone"}, {"type": "schedule", "cron": "0 0 1 * *"}],
  "actions": [
