# AI Agency Platform - Production Environment Template
# Copy this file to .env.production and customize for your deployment

# ==============================================
# CUSTOMER CONFIGURATION (Required)
# ==============================================
CUSTOMER_ID=customer_12345
CUSTOMER_TIER=professional
CUSTOMER_SUBNET=20

# ==============================================
# SERVICE PORTS (Non-overlapping ranges)
# ==============================================
# MCP Server ports (30000-30999)
MCP_PORT=30000

# PostgreSQL ports (31000-31999) 
POSTGRES_PORT=31000

# Redis ports (32000-32999)
REDIS_PORT=32000

# ==============================================
# SECURITY CREDENTIALS (Generate secure values)
# ==============================================
JWT_SECRET=your-secure-jwt-secret-here-min-32-chars
ENCRYPTION_KEY=your-32-char-encryption-key-here!!
SECURE_PASSWORD=your-secure-database-password-here

# ==============================================
# TIER-BASED RESOURCE LIMITS
# ==============================================
# Memory limits (Docker format)
TIER_MEMORY_LIMIT=2G
TIER_MEMORY_LIMIT_MB=2048

# CPU limits (Docker format)
TIER_CPU_LIMIT=2.0
TIER_CPU_LIMIT_PERCENT=200

# Rate limiting based on tier
TIER_RATE_LIMIT_RPM=1000
TIER_CONCURRENT_REQUESTS=20

# Data retention (days)
TIER_DATA_RETENTION_DAYS=90

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
APP_VERSION=1.0.0
NODE_ENV=production
LOG_LEVEL=info

# ==============================================
# AI PROVIDER SETTINGS
# ==============================================
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.1

# ==============================================
# PRODUCTION DEPLOYMENT NOTES
# ==============================================
#
# 1. Security:
#    - Generate secure random values for JWT_SECRET and ENCRYPTION_KEY
#    - Use strong database passwords (min 16 chars, mixed case, numbers, symbols)
#    - Consider using Docker Secrets or environment-specific vaults
#
# 2. Port Allocation:
#    - Each customer needs unique port ranges to avoid conflicts
#    - Increment CUSTOMER_SUBNET for each customer (20, 21, 22, etc.)
#    - Port ranges are designed for 1000 customers per range
#
# 3. Resource Scaling:
#    - Adjust TIER_* values based on customer subscription level
#    - Monitor resource usage and scale accordingly
#    - Set appropriate limits to prevent resource contention
#
# 4. Customer Isolation:
#    - Each customer gets completely isolated infrastructure
#    - Network isolation via customer-specific Docker networks
#    - Data isolation via customer-specific databases and volumes
#
# 5. Environment Customization:
#    - Copy this template for each deployment environment
#    - Staging: Use smaller resource limits and different ports
#    - Production: Use secure credentials and appropriate scaling
#